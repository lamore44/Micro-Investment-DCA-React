{
  "name": "MicroDCA",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "offline": "npm run bundle-offline && npm run build-android && npm run install-apk",
    "bundle-offline": "npx react-native bundle --platform android --dev false --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle --assets-dest android/app/src/main/res",
    "build-android": "cd android && gradlew assembleDebug",
    "install-apk": "adb install -r android/app/build/outputs/apk/debug/app-debug.apk",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "start-fresh": "react-native start --reset-cache",
    "lint": "eslint .",
    "format-check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "format": "prettier --write \"src/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^1.23.1",
    "@react-navigation/bottom-tabs": "^6.5.14",
    "@react-navigation/native": "^6.1.10",
    "@react-navigation/stack": "^6.3.20",
    "@supabase/supabase-js": "^2.106.2",
    "react": "18.2.0",
    "react-native": "0.73.4",
    "react-native-chart-kit": "^6.12.0",
    "react-native-date-picker": "^4.3.5",
    "react-native-dotenv": "^3.4.11",
    "react-native-fs": "^2.20.0",
    "react-native-gesture-handler": "2.15.0",
    "react-native-haptic-feedback": "^2.2.0",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-modal": "^13.0.1",
    "react-native-reanimated": "3.15.5",
    "react-native-safe-area-context": "^4.9.0",
    "react-native-screens": "3.29.0",
    "react-native-share": "^12.3.1",
    "react-native-svg": "14.1.0",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-vector-icons": "^10.0.3",
    "text-encoding": "^0.7.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.9",
    "@babel/preset-env": "^7.23.9",
    "@babel/runtime": "^7.23.9",
    "@react-native/eslint-config": "^0.73.2",
    "@react-native/metro-config": "^0.73.3",
    "@tsconfig/react-native": "^3.0.3",
    "@types/jest": "^29.5.12",
    "@types/react": "^18.2.6",
    "@types/react-native": "^0.73.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "prettier": "^3.8.3",
    "typescript": "5.0.4"
  }
}
